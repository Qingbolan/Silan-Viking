    "clsx": "^2.1.1",
    "framer-motion": "^11.11.9",
    "gsap": "^3.15.0",
    "i18next": "^23.15.2",
    "lucide-react": "^0.441.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^3.0.0",
    "react-i18next": "^15.0.2",
    "react-markdown": "^10.1.0",
