# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
*.log
.silan/

# dependencies
/node_modules
/desktop/node_modules
/.pnp
.pnp.js

# testing
/coverage
__pycache__
# production
/dist
/desktop/dist
/desktop/src-tauri/gen
/desktop/src-tauri/target
/api-test-portfolio

# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Environments
.venv/
venv/

# Tools
.pytest_cache/
.mypy_cache/
.pytype/
.coverage
dist/
build/
*.egg-info/

# misc
.DS_Store
.env.local
.env.development.local
.env.test.local
.env.production.local

npm-debug.log*
yarn-debug.log*
yarn-error.log*

# compiled backend helper binaries — Go build artifacts, never committed.
# The deploy pipeline builds these inside the backend Docker image; a copy
# in the worktree is a developer convenience only.
/backend/migrate
/backend/backend
/backend/silan-backend
/backend/silan-backend-mac
# A `go build` with no -o once dropped a binary named `backend` into the
# ent package directory. Guard against it being re-tracked.
/backend/internal/ent/backend

# Claude Code local runtime state — machine-local, never committed.
/.claude/

# Database snapshots taken before migrations — local backups only.
*.db.before-*.bak

# sqlite runtime databases — a derived projection of content/, rebuilt by
# `index sync`, plus the -wal / -shm files sqlite writes alongside. Local
# runtime state, never source. (The deployed db lives under /_deploy/.)
*.db
*.db-wal
*.db-shm

# silan-viking site build output — a derived artifact of `site build`,
# rebuilt from content/ on demand, never committed.
/_site/

# The content tree is its own git repository (the source of truth the
# silan-viking engine reads). It is versioned independently — this repo
# must not track its files.
/content/

# silan-viking deploy staging — a derived artifact of `site deploy`: a
# backend copy plus the projected `portfolio.db` (and its sqlite -wal / -shm
# runtime files). Rebuilt on every deploy, never committed.
/_deploy/
pr/

# Local/remote deployment credentials. Commit only deploy/.env.example.
/.env
/deploy/.env
