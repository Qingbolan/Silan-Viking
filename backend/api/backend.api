	@doc "Get episode series by slug"
	@handler GetEpisodeSeries
	get /series/:series_slug (EpisodeSeriesRequest) returns (EpisodeSeriesData)

	@doc "Get episode by slug"
	@handler GetEpisode
	get /:slug (EpisodeRequest) returns (EpisodeData)
}

// ========== MOMENTS GROUP ==========
@server (
	group:      moments
	prefix:     /api/v1/moments
	middleware: Cors,Analytics
)
service backend-api {
	@doc "Get moments list"
	@handler GetMoments
