{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Silan Context System",
  "mainBinaryName": "Silan Context System",
  "version": "1.0.0",
  "identifier": "tech.silan.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5184",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Silan Context System",
        "width": 1440,
        "height": 980
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "targets": ["app"],
    "macOS": {
      "bundleName": "Silan Context System"
    }
  }
}
