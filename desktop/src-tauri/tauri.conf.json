{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Silan Desktop",
  "version": "1.0.0",
  "identifier": "tech.silan.desktop",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 5184",
    "devUrl": "http://127.0.0.1:5184",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Silan Desktop",
        "width": 1440,
        "height": 980
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
